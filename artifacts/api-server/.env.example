
# Required secrets — set these in Replit Secrets (not in .replit or committed files)
# See: https://docs.replit.com/replit-workspace/workspace-features/secrets

# POS Kasir: HMAC-SHA256 signing secret for cashier auth tokens.
# Must be at least 32 characters. Server refuses to start without it.
# Set via: Replit Secrets panel → key "CASHIER_TOKEN_SECRET"
CASHIER_TOKEN_SECRET=<set-in-replit-secrets-min-32-chars>

# Logistic admin password for protected trucking-rate edits
LOGISTIC_ADMIN_PASSWORD=<set-in-replit-secrets>

# Google OAuth
GOOGLE_CLIENT_SECRET=<set-in-replit-secrets>

# WhatsApp (Fonnte)
FONNTE_TOKEN=<set-in-replit-secrets>
