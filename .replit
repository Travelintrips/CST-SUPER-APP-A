[userenv.development]
ADMIN_EMAIL_DOMAINS = "example.com"

[nix]
channel = "stable-25_05"
packages = ["freetype", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "tcl", "tk", "zlib"]

[objectStorage]
defaultBucketID = "replit-objstore-e357cc66-19c3-4d73-9ca9-3069d78355d1"

