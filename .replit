modules = ["nodejs-20", "web", "bash", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "gce"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Gateway"

[[workflows.workflow]]
name = "Gateway"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 5000/tcp 2>/dev/null; sleep 0.3; PORT=5000 node gateway.mjs"
args = "fuser -k 5000/tcp 2>/dev/null; sleep 0.3; API_PORT=8080 CUSTOMER_PORT=5173 BIZPORTAL_PORT=3000 PORT=5000 node gateway.mjs"
waitForPort = 5000

args = "fuser -k 5000/tcp 2>/dev/null; sleep 0.3; API_PORT=8080 BIZPORTAL_PORT=3000 CUSTOMER_PORT=5173 LOGISTIC_ORDER_PORT=19368 PORT=5000 node gateway.mjs"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

outputType = "console"

[[workflows.workflow]]
name = "BizPortal"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/bizportal && PORT=3000 BASE_PATH=/bizportal/ pnpm exec vite --config vite.config.ts --host 0.0.0.0 --port 3000"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Customer Portal"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/customer-portal && PORT=5173 BASE_PATH=/ pnpm exec vite --config vite.config.ts --host 0.0.0.0 --port 5173"
waitForPort = 5173

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Logistic Order"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/logistic-order && PORT=3001 BASE_PATH=/logistic-order/ pnpm exec vite --config vite.config.ts --host 0.0.0.0 --port 3001"
waitForPort = 3001
[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["google-drive:1.0.0", "javascript_openai_ai_integrations:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

